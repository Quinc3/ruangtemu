# Supabase — salin file ini ke .env dan isi dengan kredensial project Anda
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — HANYA untuk admin panel (jangan expose ke publik)
# Dashboard: Settings > API > service_role key
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Password halaman admin (/admin.html)
VITE_ADMIN_PASSWORD=admin123

# Storage bucket gambar (harus sama dengan supabase/storage.sql)
# Nama bucket di Supabase Storage (Dashboard → Storage), mis. ruangtemu
VITE_SUPABASE_STORAGE_BUCKET=ruangtemu

# JANGAN taruh S3 secret / access key di VITE_* — terbuka di browser.
# Upload admin memakai VITE_SUPABASE_ANON_KEY + supabase/storage.sql (RLS).
# S3 (Settings → Storage → S3) hanya untuk tools server/CLI, bukan halaman admin ini.

# Setup: SQL Editor → jalankan supabase/storage.sql — panduan: supabase/STORAGE.md
